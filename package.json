{
  "name": "claude-forge",
  "productName": "Claude Forge",
  "version": "1.0.0",
  "description": "Desktop app for managing Claude Code projects",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "start:wsl": "electron-forge start -- --no-sandbox --disable-gpu --disable-dev-shm-usage",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "build:dist": "rm -rf dist && vite build -c vite.main.prod.config.ts && vite build -c vite.preload.prod.config.ts && vite build -c vite.renderer.prod.config.ts",
    "make:win": "npm run build:dist && electron-builder --win",
    "make:linux": "npm run build:dist && electron-builder --linux",
    "make:all": "npm run build:dist && electron-builder --win --linux",
    "lint": "eslint --ext .ts,.tsx .",
    "icons": "node scripts/generate-icons.mjs"
  },
  "keywords": [],
  "author": {
    "name": "evan-hoddinott",
    "email": "evan.hoddinott@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "autoprefixer": "^10.4.27",
    "electron": "41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.7.0",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0"
  }
}
